# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ==========================================

# 1. Backend Settings
PROJECT_NAME="Smart Study Planner API"
API_V1_STR="/api/v1"

# 2. Security (Change these in production!)
SECRET_KEY="generate_a_very_long_secure_random_string_here_for_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 3. Database
# Leave as sqlite:///./test.db for simple deployment, or change to PostgreSQL URL
DATABASE_URL="sqlite+aiosqlite:///./test.db"

# 4. CORS Origins (Frontend Domain)
# Allow requests from your Vercel/Netlify/Frontend deployment domain
BACKEND_CORS_ORIGINS=["http://localhost", "https://your-frontend-domain.vercel.app"]

# 5. API Keys for AI Features
# Get this from https://aistudio.google.com/
GEMINI_API_KEY="your_google_gemini_api_key_here"
